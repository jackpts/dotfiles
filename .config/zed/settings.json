// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // check all configs here: https://gist.github.com/search?l=JSON&o=desc&q=Zed+config&s=

  "enable_language_server": true,
  "colorize_brackets": true,
  "which_key": {
    "enabled": true
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "agent_servers": {
    "mistral-vibe": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "Qwen Code": {
      "type": "custom",
      "command": "qwen",
      "args": ["--experimental-acp"],
      "env": {}
    },
    "Gemini CLI": {
      "type": "custom",
      "command": "gemini",
      "args": ["--experimental-acp"],
      "env": {}
    },
    "Kimi CLI": {
      "type": "custom",
      "command": "kimi",
      "args": ["--experimental-acp"],
      "env": {}
    }
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^ps\\s+aux(\\s|$)"
            }
          ]
        },
        "edit_file": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^\\$HOME/dotfiles/\\.config/zed/"
            }
          ]
        },
        "mcp:mcp-server-context7:query-docs": {
          "default": "allow"
        }
      }
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "stepfun/step-3.5-flash:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "qwen/qwen3-coder:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "google/gemma-3n-e4b-it:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "google/gemma-3-27b-it:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "openrouter/free",
        "enable_thinking": false
      }
    ],
    "model_parameters": [],
    // Notify Options: "primary_screen" (default), "all_screens", "never"
    "notify_when_agent_waiting": "all_screens",
    "play_sound_when_agent_done": true
  },
  "icon_theme": "Warm Charmed Icons",
  "vim_mode": true,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    // "dark": "Ayu Dark"
    // "dark": "Tokyo Night clear"
    "dark": "Uniform"
  },
  // Indentation, rainbow indentation
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  // NOTE: Zen mode, refer https://github.com/zed-industries/zed/issues/4382 when it's resolved
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15
  },
  // Inlay hints preconfigured by Zed: Go, Rust, Typescript and Svelte
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },
  // LSP
  "lsp": {
    "tailwindcss-language-server": {
      "enabled": true,
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"]
      }
    },
    // Rust-analyzer (install additionally pkgs: `paru -S rust-analyzer rust-src`)
    "rust-analyzer": {
      "enabled": true,
      "binary": {
        "path": "rust-analyzer"
      }
    },
    // TypeScript/JavaScript
    "typescript-language-server": {
      "enabled": true,
      "binary": {
        "path": "typescript-language-server",
        "arguments": ["--stdio"]
      }
    },
    // ESLint
    "eslint": {
      "enabled": true,
      "binary": {
        "path": "vscode-eslint-language-server",
        "arguments": ["--stdio"]
      }
    },

    // HTML/CSS/JSON (optional, if we need aditional features)
    "html-language-server": { "enabled": true },
    "css-language-server": { "enabled": true },
    "json-language-server": { "enabled": true }

    // For Angular: set path to lang server!
    // "languages": {
    //   "TypeScript": {
    //     "language_servers": ["typescript-language-server", "eslint", "!deno"]
    //   }
    // }
  },
  "languages": {
    // Refer https://zed.dev/docs/languages/javascript and https://zed.dev/docs/languages/typescript for more info
    "TypeScript": {
      // Refer https://github.com/jellydn/ts-inlay-hints for how to setup for Neovim and VSCode
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true
      }
    }
  },
  // File syntax highlighting
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
    "Shell Script": ["**/sway/config", "**/sway/config.d/*"]
  },
  // File scan exclusions, hide on the file explorer and search
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules"
  ],
  // Turn off telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // =================================================================
  // Font Settings
  // =================================================================
  // UI Fonts
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 17,
  "ui_font_weight": 400,

  // Buffer (Editor) Fonts - for opened files
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 17,
  "buffer_font_weight": 400,
  "buffer_line_height": "standard",

  // Terminal Fonts
  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
    "font_size": 16,
    "font_weight": 400,
    "line_height": "comfortable",
    "env": {
      "EDITOR": "zed --wait"
    }
  },

  // Agent Panel Fonts
  "agent_ui_font_size": 17,
  "agent_buffer_font_size": 16
}
